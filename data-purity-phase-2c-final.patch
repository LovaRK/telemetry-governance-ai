+import { TraceContext } from '@core/guards/trace-context';
 import { EventEmitter } from 'events';

 export interface SystemEvent {
   type: string;
   payload: any;
   timestamp: number;
 }

+export interface GovernanceEvent extends SystemEvent {
+  source: 'system';
+  mode: 'live';
+  traceId: string;
