+++ b/scripts/no-mock-check.sh
@@ -0,0 +1,20 @@
+#!/bin/bash
+
+# Data Purity Enforcement Script
+# Prevents mock, demo, fake, fallback, and sample data from entering runtime code
+
+echo "🔍 Checking for data purity violations..."
+
+VIOLATIONS=$(grep -r \
+  -E "mock|demo|fake|fallback|sample" \
+  apps/ packages/ core/ \
+  --include="*.ts" --include="*.tsx" \
+  2>/dev/null | \
+  grep -v "tests/" | grep -v "__tests__/" | grep -v ".test." | grep -v ".spec.")
+
+if [ -n "$VIOLATIONS" ]; then
+  echo "❌ Data purity violations detected:"
+  echo "$VIOLATIONS"
+  exit 1
+fi
+
+echo "✅ Data purity check passed"
