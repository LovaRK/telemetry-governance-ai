// This is a partial schema showing the ExecutionJournal model
// Merge this into your existing prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Decision {
  id                    String    @id @default(uuid())
  tenantId              String
  snapshotId            String
  index                 String
  decision              String    // ELIMINATE, RETAIN, MONITOR, REBALANCE, ESCALATE
  status                String    @default("UNDER_REVIEW") // UNDER_REVIEW, APPROVED, EXECUTED, REJECTED_FINAL, DEFERRED
  compositeScore        Float
  annualCostUsd         Float
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  executedAt            DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  deferredAt            DateTime?
  deferredUntil         DateTime?
  deferredReason        String?
  reawokenAt            DateTime?
  reawokenCount         Int       @default(0)
  approverAccountId     String?
  rejectionReason       String?
  executionJournals     ExecutionJournal[]
  auditEvents           AuditEvent[]

  @@unique([tenantId, snapshotId, index])
  @@index([status])
  @@index([tenantId, status])
  @@index([deferredUntil]) // For sweeper query
}

model ExecutionJournal {
  id              String    @id @default(uuid())
  decisionId      String
  decision        Decision  @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  tenantId        String
  idempotencyKey  String    @unique
  status          String    @default("STARTED") // STARTED, COMPLETED, FAILED, ROLLED_BACK
  externalState   Json?     // { status: 'success' | 'failed' | 'unknown', externalId?, error? }

  // Data Purity Tracking (Phase 2C.1)
  source          String?   // 'splunk', 'postgres', 'system' - Phase 3 will enforce NOT NULL
  mode            String?   // 'live' - Phase 3 will enforce NOT NULL
  traceId         String?   // UUID - W3C Trace Context correlation ID

  // Audit relationships
  auditEvents     DataPurityAudit[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([decisionId])
  @@index([tenantId, status]) // For reconciliation queries
  @@index([traceId]) // For audit trail replay
  @@index([source, createdAt]) // For data provenance analysis
  @@map("execution_journal")
}

model DataPurityAudit {
  id                  BigInt                @id @default(autoincrement())
  executionJournal    ExecutionJournal      @relation(fields: [executionJournalId], references: [id], onDelete: Cascade)
  executionJournalId  String
  source              String                // 'splunk', 'postgres', 'system'
  mode                String                // 'live'
  traceId             String                // UUID
  violationType       String?               // Type of violation detected
  violationMessage    String?               // Detailed violation message
  validationTimestamp DateTime              @default(now())
  createdAt           DateTime              @default(now())

  @@index([executionJournalId, validationTimestamp])
  @@index([traceId, createdAt])
  @@index([violationType, createdAt]) // For drift detection queries
  @@map("data_purity_audit")
}

model AuditEvent {
  id            String    @id @default(uuid())
  decisionId    String
  decision      Decision  @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  tenantId      String
  actorId       String
  eventType     String    // execution.completed, execution.success, execution.failed, etc.
  payload       Json
  createdAt     DateTime  @default(now())

  @@index([decisionId])
  @@index([tenantId, createdAt])
  @@map("audit_events")
}
