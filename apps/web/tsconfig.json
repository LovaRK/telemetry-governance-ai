{
  "compilerOptions": {
    "target": "es2015",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "downlevelIteration": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@api/*": [
        "../../apps/api/*"
      ],
      "@core/*": [
        "../../core/*"
      ],
      "@agents/*": [
        "../../agents/*"
      ],
      "@tools/*": [
        "../../tools/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../../apps/api/**/*",
    "../../agents/**/*",
    "../../tools/**/*",
    "../../docker/**/*",
    "../../core/**/*",
    "examples",
    "hooks",
    "src",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
