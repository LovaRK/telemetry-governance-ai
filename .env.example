# ============================================
# datasensAI — environment template
# Copy to .env and fill in. NEVER commit your real .env.
#   cp .env.example .env
# ============================================

# ── Ports (host side) ───────────────────────
WEB_PORT=3002
POSTGRES_PORT=5433
NODE_ENV=development

# ── Admin user (created on first startup) ───
# Required. Pick your own; the app creates this admin on first boot.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Secrets — generate fresh, do NOT reuse any value you've seen ──
# Generate each with:  openssl rand -hex 32
SPLUNK_SECRET_ENCRYPTION_KEY=
GOVERNANCE_BOOTSTRAP_KEY=

# ── Splunk connection (OPTIONAL bootstrap) ──
# Leave blank and configure per-tenant in the UI (Settings → Splunk Connection).
# Only set these to pre-seed the first tenant's connection.
#   NEXT_PUBLIC_SPLUNK_MCP_URL=https://<your-splunk-host>:8089
#   NEXT_PUBLIC_SPLUNK_TOKEN=Basic <base64(user:password)>   # or: Bearer <token>
NEXT_PUBLIC_SPLUNK_MCP_URL=
NEXT_PUBLIC_SPLUNK_TOKEN=
NEXT_PUBLIC_SPLUNK_DISABLE_SSL_VERIFY=true

# ── LLM ─────────────────────────────────────
# Path A (default, fully local): install Ollama + `ollama pull gemma2:9b`
LLM_MODEL=gemma2:9b
# Path B (fallback): set a key here AND select Anthropic in Settings → AI Provider.
# No silent fallback — local stays primary unless you explicitly opt in.
ANTHROPIC_API_KEY=

# ── Health check tuning (optional) ──────────
HEALTH_CHECK_INTERVAL=10s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=5
