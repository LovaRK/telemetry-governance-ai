# ============================================
# Application Configuration
# ============================================

# Port mappings (host:container)
WEB_PORT=3002
POSTGRES_PORT=5433

# Node environment
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# Note: DATABASE_URL in docker-compose.yml points to postgres service
# Change only if using external database

# ============================================
# Admin User (created on first startup)
# ============================================
# These credentials are used to create the initial admin user
# Only set if you want custom credentials (defaults: admin@bitso.com / Admin@12345)
ADMIN_EMAIL=admin@bitso.com
ADMIN_PASSWORD=Admin@12345

# ============================================
# Splunk Configuration
# ============================================
# Splunk HTTP Event Collector (HEC) endpoint and token
# These are set in docker-compose.yml and can be overridden here
NEXT_PUBLIC_SPLUNK_MCP_URL=https://144.202.48.85:8089
NEXT_PUBLIC_SPLUNK_TOKEN=Basic cmFtOlJhbWFAMTk4OA==
NEXT_PUBLIC_SPLUNK_DISABLE_SSL_VERIFY=true

# ============================================
# LLM Configuration
# ============================================
# Local Ollama model or cloud-hosted API
LLM_MODEL=gemma2:9b
ANTHROPIC_API_KEY=

# ============================================
# Governance Configuration
# ============================================
# Governance bootstrap key for ledger initialization
GOVERNANCE_BOOTSTRAP_KEY=75512d550a46fc514ca7874ba7fee1244f39303d99a782e82cbcfd2097ee03cd

# ============================================
# Health Check Configuration
# ============================================
HEALTH_CHECK_INTERVAL=10s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=5

# ============================================
# Worker Configuration
# ============================================
WORKER_POLL_INTERVAL_MS=5000
OLLAMA_BASE_URL=http://host.docker.internal:11434
