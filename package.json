{
  "name": "agentic-telemetry-dashboard",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "core",
    "agents",
    "tools"
  ],
  "scripts": {
    "dev": "docker-compose -f docker/docker-compose.yml up",
    "build": "docker-compose build",
    "clean": "docker-compose down -v",
    "migrate": "node scripts/init-db.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:chaos": "vitest run --config vitest.chaos.config.ts",
    "test:chaos:watch": "vitest --config vitest.chaos.config.ts",
    "test:chaos:coverage": "vitest run --config vitest.chaos.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:watch": "playwright test --watch",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "bullmq": "^5.76.10",
    "redis": "^5.12.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
