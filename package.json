{
  "name": "agentic-telemetry-dashboard",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "core",
    "agents",
    "tools"
  ],
  "scripts": {
    "validate:tenant-context": "node scripts/validate-tenant-context.js",
    "verify": "npm run validate:tenant-context && npm run typecheck && npm run test && npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx 2>/dev/null || true",
    "dev": "docker-compose -f docker/docker-compose.yml up",
    "build": "docker-compose -f docker/docker-compose.yml build",
    "clean": "docker-compose -f docker/docker-compose.yml down -v",
    "migrate": "node scripts/init-db.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:chaos:invariants": "vitest run --config vitest.chaos-invariants.config.ts",
    "test:chaos:invariants:watch": "vitest --config vitest.chaos-invariants.config.ts",
    "test:chaos:invariants:coverage": "vitest run --config vitest.chaos-invariants.config.ts --coverage",
    "test:chaos:infra": "vitest run --config vitest.chaos.config.ts",
    "test:chaos:infra:watch": "vitest --config vitest.chaos.config.ts",
    "test:chaos:infra:coverage": "vitest run --config vitest.chaos.config.ts --coverage",
    "test:chaos": "npm run test:chaos:invariants && npm run test:chaos:infra",
    "test:chaos:watch": "vitest --config vitest.chaos.config.ts",
    "test:chaos:coverage": "vitest run --config vitest.chaos.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:watch": "playwright test --watch",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:contract": "jest -c jest.gates.config.js tests/contract",
    "test:fixtures": "jest -c jest.gates.config.js tests/agent_reasoning/recommendation.test.ts",
    "test:agent": "jest -c jest.gates.config.js tests/agent_reasoning",
    "test:pipeline": "jest -c jest.gates.config.js tests/pipeline",
    "test:ui": "playwright test --config playwright.ui.config.ts",
    "test:all-gates": "npm run test:contract && npm run test:fixtures && npm run test:agent && npm run test:pipeline && npm run test:ui && npm run test:e2e",
    "seed:test": "node scripts/seed-fixtures.js",
    "cleanup:test": "node scripts/cleanup-fixtures.js",
    "verify:clean": "node scripts/verify-clean.js",
    "test:all-gates:clean": "npm run seed:test && npm run test:all-gates && npm run cleanup:test && npm run verify:clean",
    "pre-release-check": "bash scripts/pre-release-check.sh"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "bullmq": "^5.76.10",
    "redis": "^5.12.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.60.0",
    "@prisma/client": "^7.8.0",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "ioredis": "^5.10.1",
    "jest": "^29.7.0",
    "node-fetch": "^3.3.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
