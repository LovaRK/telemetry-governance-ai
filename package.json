{
  "name": "agentic-telemetry-dashboard",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "core",
    "agents",
    "tools"
  ],
  "scripts": {
    "dev": "docker-compose -f docker/docker-compose.yml up",
    "build": "docker-compose build",
    "clean": "docker-compose down -v",
    "migrate": "node scripts/init-db.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "bullmq": "^5.76.10",
    "redis": "^5.12.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
