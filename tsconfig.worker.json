{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node"],
    "outDir": "./dist-worker",
    "rootDir": ".",
    "paths": {
      "@api/*": ["./apps/api/*"],
      "@core/*": ["./core/*"],
      "@agents/*": ["./agents/*"],
      "@packages/auth/*": ["./packages/auth/*"]
    }
  },
  "include": [
    "docker/worker.ts",
    "apps/api/**/*.ts",
    "core/**/*.ts",
    "agents/**/*.ts",
    "packages/**/*.ts"
  ],
  "exclude": ["node_modules", "apps/web"]
}
