# datasensAI Demo Environment Configuration
# Copy to .env and fill in values

# Splunk connection (REQUIRED)
SPLUNK_HOST=144.202.48.85
SPLUNK_PORT=8089
SPLUNK_USERNAME=ram
SPLUNK_PASSWORD=
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=false

# HEC (optional, used for faster event loading)
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# Demo mode (REQUIRED)
DATASENSAI_MODE=demo

# Run ID (CRITICAL: explicit run ID to prevent duplicate-load corruption)
DATASENSAI_RUN_ID=1stmile-demo-20260626-001

# Reset confirmation (safety guardrail)
CONFIRM_RESET_DATASENSAI_DEMO=false

# Usage:
# 1. source config/datasensai.demo.env
# 2. python tools/splunk_reverse_engineering/reverse_engineer_1stmile.py
# 3. python tools/splunk_reverse_engineering/generate_events.py
# 4. python tools/splunk_reverse_engineering/validate_demo_environment.py --static-only
# 5. python tools/splunk_reverse_engineering/create_indexes.py --dry-run
# 6. python tools/splunk_reverse_engineering/load_events.py --dry-run
# 7. (After approval) python tools/splunk_reverse_engineering/create_indexes.py --force
# 8. (After approval) python tools/splunk_reverse_engineering/load_events.py --force
# 9. python tools/splunk_reverse_engineering/validate_demo_environment.py
